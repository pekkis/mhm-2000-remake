{
  "name": "mhm-97-remake",
  "version": "3.0.0",
  "description": "A remake of MHM 97",
  "keywords": [
    "MHM 97",
    "remake"
  ],
  "license": "MIT",
  "author": "Pekkis",
  "repository": {
    "type": "git",
    "url": "https://github.com/pekkis/mhm-97-remake"
  },
  "type": "module",
  "main": "src",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "lint": "oxlint .",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "typecheck": "tsgo --noEmit",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:ui": "vitest --ui",
    "verify": "pnpm run test --run && pnpm run format && pnpm run lint --fix && pnpm run typecheck"
  },
  "dependencies": {
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/sprinkles": "^1.6.5",
    "@xstate/react": "^6.1.0",
    "@xstate/store": "^3.17.1",
    "@xstate/store-react": "^1.0.1",
    "clsx": "^2.1.1",
    "immer": "^11.1.4",
    "random-js": "^2.1.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.73.1",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.14.2",
    "react-router-dom": "^7.14.2",
    "remeda": "^2.33.7",
    "xstate": "^5.30.0",
    "zod": "^4.3.6"
